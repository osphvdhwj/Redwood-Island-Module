<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Dynamic Island Configuration"
        android:textSize="24sp"
        android:layout_marginBottom="24dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Y Offset" />
    <SeekBar
        android:id="@+id/seekBarYOffset"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:max="100"
        android:progress="0" />

    <TextView
        android:id="@+id/tvRingOffsetY"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Ring Y Offset"
        android:layout_marginTop="16dp"/>
    <SeekBar
        android:id="@+id/seekBarRingOffsetY"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:max="200"
        android:progress="148" />

    <Button
        android:id="@+id/btnSave"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Save &amp; Apply"
        android:layout_marginTop="24dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Note: Changes require a quick system reload via broadcast."
        android:textSize="12sp"
        android:textColor="@android:color/darker_gray"
        android:layout_marginTop="16dp"/>
    <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Premium Features"
            android:textStyle="bold"
            android:textSize="18sp"
            android:layout_marginTop="32dp"
            android:layout_marginBottom="16dp"
            android:textColor="#FFFFFF"/>

        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/switch_hide_landscape"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Auto-Hide in Landscape (Gaming/Video)" 
            android:textColor="#CCCCCC"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Haptic Strength (0=Off, 3=Heavy)"
            android:textColor="#CCCCCC"
            android:layout_marginTop="24dp"/>
        <SeekBar
            android:id="@+id/seek_haptic"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="3"
            android:progress="1"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Background Blur Quality (0=Off, 24=Max)"
            android:textColor="#CCCCCC"
            android:layout_marginTop="24dp"/>
        <SeekBar
            android:id="@+id/seek_blur"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="24"
            android:progress="16"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Charging Animation Style"
            android:textColor="#CCCCCC"
            android:layout_marginTop="24dp"/>
        <Spinner
            android:id="@+id/spinner_charging_style"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:backgroundTint="#FFFFFF"
            android:layout_marginTop="8dp"/>
    <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Physics & Animation Tuning"
            android:textStyle="bold"
            android:textSize="18sp"
            android:layout_marginTop="32dp"
            android:layout_marginBottom="16dp"
            android:textColor="#FFFFFF"/>

        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/switch_glassmorphism"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="True Glassmorphism (Translucent Background)" 
            android:textColor="#CCCCCC"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Animation Bounciness (Lower = More Wobble)"
            android:textColor="#CCCCCC"
            android:layout_marginTop="24dp"/>
        <SeekBar
            android:id="@+id/seek_damping"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="100"
            android:progress="85"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Animation Speed/Stiffness"
            android:textColor="#CCCCCC"
            android:layout_marginTop="24dp"/>
        <SeekBar
            android:id="@+id/seek_stiffness"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="1000"
            android:progress="400"/>
</LinearLayout>
