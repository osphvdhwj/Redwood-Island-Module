<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- 🛡️ SHARED SECURITY PERMISSION -->
    <permission
        android:name="com.redwood.permission.SECURE_IPC"
        android:protectionLevel="signature" />

    <uses-permission android:name="com.redwood.permission.SECURE_IPC" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="Redwood Satellite"
        android:supportsRtl="true">

        <!-- 🛰️ XPOSED MODULE META-DATA -->
        <meta-data
            android:name="xposedmodule"
            android:value="true" />
        <meta-data
            android:name="xposeddescription"
            android:value="Ghost Satellite hooks for Redwood Core" />
        <meta-data
            android:name="xposedminversion"
            android:value="93" />
        <meta-data
            android:name="xposedscope"
            android:resource="@array/xposed_scope" />

        <!-- 🧠 IPC Provider (Legacy Support) -->
        <provider
            android:name=".ipc.IslandContentProvider"
            android:authorities="com.example.dynamicisland.provider"
            android:exported="true"
            android:multiprocess="true"
            android:syncable="false" />

    </application>
</manifest>
